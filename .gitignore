__pycache__/
*.pyc
.env
*.log
logs/

# Local secrets and runtime state — never commit
.gemini_key
.gemini_model
window_state.json

# Local-first caches of the Google Sheet (the source of truth) + the persisted
# active-narrative choice. Committing these is a stale-data trap — a fresh clone
# would load OLD Sheet data from git instead of re-syncing on launch. The Sheet
# is canon (see the Sheets state machine); these regenerate from it.
player_state.json
quest_cache*.json
active_narrative.txt

# -- Build outputs: derived, rebuilt per machine, never tracked --
# _internal is a directory JUNCTION to ../_runtime; without this, GitHub Desktop
# walks into it and offers every shared-runtime file for commit.
/_internal/
/build/
/dist/
/archive/
/__trace_spec__/
*.spec
*.exe

# NOTE: scenes/*.png ARE committed on purpose — a generated scene image is
# canonical game art, baked into the repo so it travels with a fresh clone and
# reloads on revisit/relaunch instead of re-commissioning the painter.

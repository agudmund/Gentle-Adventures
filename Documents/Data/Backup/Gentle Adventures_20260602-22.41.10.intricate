    {
      "node_id": 0,
      "node_type": "warm",
      "title": "Growth",
      "uuid": "0f5c828d0de04046a93d588852018d5b",
      "x": 9696.885601965092,
      "y": 3533.0796817432247,
      "width": 300.0,
      "height": 206.0,
      "z_value": -9.932000000000038,
      "ports_visible": false,
      "shelf_visible": true,
      "body_text": "* **Creating new directories**: Using the `mkdir` command or the File Explorer.\n* **Deleting files and directories**: Using the `rm` command or the File Explorer.\n* **Copying files and directories**: Using the `cp` command or the File Explorer.\n* **Moving files and directories**: Using the `mv` command or the File Explorer."
    },
    {
      "node_id": 0,
      "node_type": "warm",
      "title": "Golden Hour",
      "uuid": "335f3878818542b1918cc92a3c12e87d",
      "x": 10498.563065123224,
      "y": 3748.602704753049,
      "width": 300.0,
      "height": 236.0,
      "z_value": -9.92900000000004,
      "ports_visible": false,
      "shelf_visible": true,
      "body_text": "* **Backup your data**: Regularly backing up your files and directories is essential for ensuring the security and integrity of your data.\n* **Use compression**: Compressing files can help reduce storage space and improve transfer times.\n* **Use encryption**: Encrypting files can help protect them from unauthorized access.\n* **Use secure passwords**: Using secure passwords can help protect your files and directories from unauthorized access."
    },
    {
      "node_id": 0,
      "node_type": "warm",

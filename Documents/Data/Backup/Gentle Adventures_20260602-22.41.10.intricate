      "z_value": -9.858000000000079,
      "ports_visible": false,
      "shelf_visible": true,
      "body_text": "**Chapter 8: The Conclusion**"
    },
    {
      "node_id": 0,
      "node_type": "warm",
      "title": "Onward",
      "uuid": "5d4629bc965a4c078e61f52326516663",
      "x": 24398.804547634198,

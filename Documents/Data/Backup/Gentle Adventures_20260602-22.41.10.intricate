      "ports_visible": false,
      "shelf_visible": true,
      "body_text": "**How Filesystems Work**"
    },
    {
      "node_id": 0,
      "node_type": "warm",
      "title": "Grace",
      "uuid": "fcc4a1bd941b4414b17c6c5d72e9e7a9",

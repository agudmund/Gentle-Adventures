      "width": 300.0,
      "height": 176.0,
      "z_value": -9.955000000000025,
      "ports_visible": false,
      "shelf_visible": true,
      "body_text": "* **Root directory**: The topmost directory in the hierarchy.\n* **Subdirectories**: Directories that are located inside other directories.\n* **Files**: The actual data stored on a storage device."
    },
    {
      "node_id": 0,
      "node_type": "warm",
      "title": "Pure Light",
